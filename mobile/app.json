{
  "expo": {
    "name": "Valgaron",
    "slug": "valgaron-mobile",
    "scheme": "valgaron",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "platforms": ["android", "ios", "web"],
    "plugins": [
      "./plugins/withEmbeddedDebugBundle.cjs",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Valgaron to choose images for local codex entries.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-sharing"
    ],
    "android": {
      "package": "com.valgaron.mobile"
    },
    "extra": {
      "localOnly": true,
      "storageModel": "device-local"
    }
  }
}
